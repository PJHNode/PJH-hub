{
  "name": "pjh-hub",
  "version": "2.0.0",
  "description": "Zero-Knowledge Platform powered by Cloudflare Workers",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "cd apps/quiet-room && python -m http.server 8080",
    "deploy:relay": "cd workers/relay && wrangler deploy",
    "deploy:notice": "cd workers/notice && wrangler deploy",
    "deploy:admin": "cd workers/admin && wrangler deploy",
    "deploy:api": "cd workers/api && wrangler deploy",
    "deploy": "npm run deploy:relay && npm run deploy:notice && npm run deploy:admin && npm run deploy:api",
    "test": "vitest",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [
    "zero-knowledge",
    "encryption",
    "cloudflare-workers",
    "websocket",
    "e2ee"
  ],
  "author": "PJH Hub",
  "license": "MIT",
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^2.8.8",
    "vitest": "^0.34.6"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
